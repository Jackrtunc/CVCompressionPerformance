{
  "name": "Final Project",
  "image": "pytorch/pytorch:2.5.1-cuda12.1-cudnn9-runtime",
  "runArgs": ["--gpus", "all"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-ossdata.vscode-pgsql"
      ],
      "settings": {
        "terminal.integrated.shell.linux": "/bin/bash"
      }
    }
  },
  "remoteUser": "root",
  "remoteEnv": {
        "PYTHONPATH": "${containerWorkspaceFolder}"
    }
}
